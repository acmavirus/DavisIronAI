# Biến môi trường mẫu cho Davis Iron AI
# Copy file này thành .env và điền thông tin thực tế

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=8722512969:your_token_here
WHITELIST_USER_ID=your_telegram_id_here

# Cấu hình tùy chọn
TELEGRAM_BOT_CHANNEL=

# Cấu hình Phiên bản & Cập nhật
# Lưu ý: APP_VERSION ở đây chỉ dùng cho môi trường chạy code (Dev).
# Bản .exe khi phát hành sẽ tự động lấy version từ file trong thư mục changelogs/.
APP_VERSION=1.0.0
GITHUB_REPO=acmavirus/DavisIronAI